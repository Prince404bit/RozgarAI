# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
PORT=5000

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///rural_employment.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/kaammitr

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/
# Without this key, the app uses a rule-based fallback (still fully functional)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Twilio (optional — for IVR/SMS features) ──────────────────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE=+1xxxxxxxxxx

# ── Public Base URL ────────────────────────────────────────────────────────────
# Used for Twilio webhooks. Use ngrok for local testing.
# Example: https://abc123.ngrok.io
BASE_URL=http://localhost:5000
